---
import logo from '../assets/logo.png';
import '../styles/global.css';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
		<link rel="icon" type="image/png" href={logo.src} />
		<meta name="generator" content={Astro.generator} />
		<title>Sky Drink | Work Hard. No Excuses.</title>
		<!-- SEO Best Practices -->
		<meta name="description" content="Sky Drink is the ultimate energy drink from Guwahati, Assam. Instant energy, sharper focus, zero compromises. Work Hard. No Excuses." />
		<meta name="keywords" content="Sky Drink, Energy Drink, Guwahati, Assam, Mango Fizz, Lychee Fizz, Spice Vibe, Hustle" />
	</head>
	<body class="bg-zinc-950 text-white overflow-x-hidden selection:bg-yellow-400 selection:text-black">
		<slot />
	</body>
</html>
