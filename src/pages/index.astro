---
import Layout from '../layouts/Layout.astro';
import CustomCursor from '../components/CustomCursor.jsx';
import EnergyBar from '../components/EnergyBar.jsx';
import Navbar from '../components/Navbar.jsx';

import Hero from '../components/Hero.astro';
import Marquee from '../components/Marquee.astro';
import Flavors from '../components/Flavors.astro';
import PriceTag from '../components/PriceTag.astro';

import RootsMap from '../components/RootsMap.jsx';
import VibeCheck from '../components/VibeCheck.jsx';
import InstagramIcon from '../components/InstagramIcon.jsx';
---

<Layout>
  <!-- React Global Micro-interactions -->
  <CustomCursor client:only="react" />
  <EnergyBar client:only="react" />
  <Navbar client:load />

  <main>
    <Hero />
    <Marquee />
    <Flavors />
    <PriceTag />
    <RootsMap client:load />
    <VibeCheck client:load />
  </main>

  <footer class="bg-black py-12 border-t border-zinc-900 relative z-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pr-8 md:pr-12 flex flex-col md:flex-row justify-between items-center gap-6">
      
      <div class="flex flex-col items-center md:items-start gap-2">
        <div class="flex items-center clickable">
          <img 
            src="/logo.png" 
            alt="Sky Drink Logo" 
            class="h-28 md:h-32 w-auto [filter:drop-shadow(0_0_12px_rgba(255,255,255,0.15))]" 
          />
        </div>
        <p class="text-zinc-600 font-medium text-sm">© 2026 Sky Drink. Guwahati, Assam.</p>
      </div>

      <div class="flex items-center gap-6">
        <a href="https://www.instagram.com/skydrink.official_/" target="_blank" rel="noreferrer" class="clickable text-zinc-400 hover:text-white transition-colors">
          <InstagramIcon className="w-8 h-8" />
        </a>
      </div>

    </div>
  </footer>

  <!-- GSAP Integration Script -->
  <script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    // Initial setup
    gsap.set('.gs-fade-up', { y: 50, opacity: 0 });
    
    // MatchMedia for mobile vs desktop animations
    let mm = gsap.matchMedia();

    mm.add("(min-width: 768px)", () => {
      // Desktop animations
      gsap.utils.toArray('.gs-fade-up').forEach((elem) => {
        const el = elem as HTMLElement;
        let delay = el.classList.contains('gs-delay') ? 0.3 : 0;
        gsap.to(el, {
          y: 0,
          opacity: 1,
          duration: 0.8,
          ease: "power3.out",
          delay: delay,
          scrollTrigger: {
            trigger: el,
            start: "top 85%",
            toggleActions: "play none none reverse"
          }
        });
      });
    });

    mm.add("(max-width: 767px)", () => {
      // Mobile animations (reduced motion / no delay)
      gsap.utils.toArray('.gs-fade-up').forEach((elem) => {
        const el = elem as HTMLElement;
        gsap.to(el, {
          y: 0,
          opacity: 1,
          duration: 0.5,
          ease: "power2.out",
          scrollTrigger: {
            trigger: el,
            start: "top 90%",
            toggleActions: "play none none none"
          }
        });
      });
    });
  </script>
</Layout>
