---
import promoVideo from '../assets/Sky-Drink-promo.mp4';
---

<section class="relative min-h-screen flex items-center pt-20 overflow-hidden" id="showcase">
  <!-- Glowing Background Ambience -->
  <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-yellow-500/20 rounded-full blur-[120px] mix-blend-screen pointer-events-none"></div>
  <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-orange-500/20 rounded-full blur-[120px] mix-blend-screen pointer-events-none"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full relative z-10 grid lg:grid-cols-2 gap-12 items-center pr-8 md:pr-12">
    
    <div class="flex flex-col gap-6 text-center lg:text-left order-2 lg:order-1 gs-fade-up">
      <div class="inline-flex items-center justify-center lg:justify-start gap-2 text-yellow-400 font-bold uppercase tracking-widest text-sm mb-2">
        <!-- MapPin inline SVG -->
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
        <span>Born in Guwahati, Assam</span>
      </div>
      
      <h1 class="text-6xl sm:text-7xl lg:text-9xl font-black uppercase leading-[0.9] tracking-tighter">
        Work Hard.<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-yellow-400 via-orange-500 to-yellow-400">
          No Excuses.
        </span>
      </h1>
      
      <p class="text-xl sm:text-2xl text-zinc-400 font-medium max-w-xl mx-auto lg:mx-0">
        The ultimate fuel for the unstoppable. Instant energy, sharper focus, zero compromises.
      </p>
      
      <div class="flex flex-col sm:flex-row items-center gap-4 mt-8 justify-center lg:justify-start">
        <a href="#flavors" class="clickable w-full sm:w-auto px-8 py-4 bg-white text-black font-black uppercase tracking-wider text-lg rounded-full hover:bg-zinc-200 transition-all flex items-center justify-center gap-2 group">
          Fuel Your Hustle
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>
        <div class="text-2xl font-black text-yellow-400 px-6 py-3 border-2 border-yellow-400/30 rounded-full bg-yellow-400/5">
          ONLY ₹20
        </div>
      </div>
    </div>

    <!-- Transparent Video Pod -->
    <div class="order-1 lg:order-2 flex justify-center lg:justify-end relative gs-fade-up gs-delay">
      <div class="relative w-full max-w-sm shrink-0 aspect-[9/16] group clickable">
        <!-- Optional: A very subtle glow behind the bottle since it's transparent, helping it pop -->
        <div class="absolute inset-0 bg-yellow-400/10 blur-[80px] rounded-full pointer-events-none z-0"></div>
        <video 
          src={promoVideo} 
          autoplay 
          loop 
          muted 
          playsinline
          class="w-full h-full object-cover transform scale-105 group-hover:scale-100 transition-transform duration-700 relative z-10"
        ></video>
        
        <div class="absolute bottom-6 left-0 w-full text-center z-20 pointer-events-none">
          <span class="inline-block bg-yellow-400 text-black px-4 py-1 font-black uppercase text-sm rounded-full mb-2 animate-pulse shadow-[0_0_10px_rgba(250,204,21,0.8)]">
            New Arrival
          </span>
          <h3 class="text-2xl font-black uppercase tracking-wide text-white drop-shadow-md">
            Mango Fizz 360°
          </h3>
        </div>
      </div>
    </div>

  </div>
</section>
